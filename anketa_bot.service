[Unit]
Description=anketa_bot
After=network.target

[Service]
User=root
WorkingDirectory=/root/apps/bots/anketa_bot
ExecStart=/root/apps/bots/anketa_bot/venv/bin/python /root/apps/bots/anketa_bot/main.py
Restart=always
RestartSec=3
Environment="PYTHONUNBUFFERED=1"

[Install]
WantedBy=multi-user.target
